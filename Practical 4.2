import numpy as np

def get_matrix_input(rows, cols):
    print(f"Enter elements for a {rows}x{cols} matrix (row-wise):")
    elements = []
    for i in range(rows):
        row = list(map(int, input(f"Row {i+1}: ").split()))
        elements.append(row)
    return np.array(elements)

# Input for 5x3 Matrix
print("Matrix 1 (5x3)")
mat1 = get_matrix_input(5, 3)

# Input for 3x2 Matrix
print("\nMatrix 2 (3x2)")
mat2 = get_matrix_input(3, 2)

# Matrix Multiplication
# Using np.dot() or the @ operator
product_matrix = np.dot(mat1, mat2)

print("\nProduct Matrix (5x2):")
print(product_matrix)
