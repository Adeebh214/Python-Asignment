# Taking input and converting to tuple
data_input = input("Enter a series of integers separated by space: ")
user_list = [int(x) for x in data_input.split()]
my_tuple = tuple(user_list)

# a) Print the total number of items
print(f"Total number of items: {len(my_tuple)}")

# b) Print the Tuple elements
print(f"Tuple elements: {my_tuple}")

# c) Check for the integer 5
if 5 in my_tuple:
    print("Contains 5: Yes")
else:
    print("Contains 5: No")

# d) Remove first item, sort the remaining, and print
# Note: Tuples are immutable, so we convert to a list to modify
temp_list = list(my_tuple)
if len(temp_list) > 0:
    temp_list.pop(0)  # Remove first item
    temp_list.sort()  # Sort remaining
    print(f"Remaining items sorted: {temp_list}")
else:
    print("Tuple was empty, nothing to sort.")
    
