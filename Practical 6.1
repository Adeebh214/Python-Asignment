text = input("Enter a string: ")

vowels_count = 0
consonants_count = 0
spaces_count = 0
lowercase_count = 0

vowels = "aeiouAEIOU"

for char in text:
    # Check for lowercase letters
    if char.islower():
        lowercase_count += 1
    
    # Check for spaces
    if char == " ":
        spaces_count += 1
    
    # Check for alphabets (Vowels vs Consonants)
    if char.isalpha():
        if char in vowels:
            vowels_count += 1
        else:
            consonants_count += 1

print("-" * 25)
print(f"Number of Vowels: {vowels_count}")
print(f"Number of Consonants: {consonants_count}")
print(f"Number of Spaces: {spaces_count}")
print(f"Number of Lowercase Letters: {lowercase_count}")
print("-" * 25)
